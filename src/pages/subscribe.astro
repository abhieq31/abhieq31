---
import Base from '../layouts/Base.astro';
import { site } from '../config';
const action = site.newsletter?.action || '#';
---
<Base title="Subscribe" description={`Subscribe to ${site.name} — new posts in your inbox.`}>
  <div class="container subscribe-page">
    <h1 class="page-title">Subscribe</h1>
    <p class="lead">Get the podcast in your inbox.</p>

    <form class="subscribe-form subscribe-form-compact" action={action} method="post" target="_blank">
      <input type="email" name="email" placeholder="Email" required aria-label="Email address" autocomplete="email" />
      <button class="btn" type="submit">Subscribe</button>
    </form>
  </div>
</Base>
