---
import IconBrandX from "@/assets/icons/IconBrandX.svg";
import IconGitHub from "@/assets/icons/IconGitHub.svg";
import { SOCIALS } from "@/constants";
import LinkButton from "./LinkButton.astro";

export interface Props {
  centered?: boolean;
}

const { centered = false } = Astro.props;

const iconMap = {
  twitter: IconBrandX,
  github: IconGitHub,
};
---

<div class:list={["relative flex-wrap justify-center gap-1", { flex: centered }]}>
  {
    SOCIALS.filter(social => social.active).map(social => {
      const IconComponent = iconMap[social.icon as keyof typeof iconMap];
      return (
        <LinkButton
          href={social.href}
          id={social.icon === "github" ? "github-social" : undefined}
          class="p-2 hover:rotate-6 sm:p-1"
          title={social.linkTitle}
        >
          {IconComponent && (
            <IconComponent class="inline-block size-6 scale-125 fill-transparent stroke-current stroke-2 opacity-90 group-hover:fill-transparent sm:scale-110" />
          )}
          <span class="sr-only">{social.linkTitle}</span>
        </LinkButton>
      );
    })
  }

  <!-- GitHub contribution graph: opens on hover, click opens the profile -->
  <div
    id="gh-graph"
    class="invisible absolute bottom-full left-1/2 z-20 mb-3 w-[330px] max-w-[80vw] -translate-x-1/2 rounded-lg border border-border bg-background p-3 opacity-0 shadow-xl transition-opacity duration-150"
  >
    <a href="https://github.com/abhieq31" target="_blank" rel="me noopener" class="block">
      <img
        src="https://ghchart.rshah.org/abhieq31"
        alt="Abhi's GitHub contribution graph"
        class="w-full"
        loading="lazy"
      />
      <p class="mt-2 text-center text-xs text-foreground/60">Open GitHub profile →</p>
    </a>
  </div>
</div>

<script>
  function setupGithubGraph() {
    const link = document.getElementById("github-social");
    const graph = document.getElementById("gh-graph");
    if (!link || !graph) return;
    let hideTimer: ReturnType<typeof setTimeout> | undefined;
    const show = () => {
      clearTimeout(hideTimer);
      graph.classList.remove("invisible", "opacity-0");
    };
    const hide = () => {
      hideTimer = setTimeout(() => graph.classList.add("invisible", "opacity-0"), 150);
    };
    link.addEventListener("mouseenter", show);
    link.addEventListener("focus", show);
    link.addEventListener("mouseleave", hide);
    link.addEventListener("blur", hide);
    graph.addEventListener("mouseenter", show);
    graph.addEventListener("mouseleave", hide);
  }
  document.addEventListener("astro:page-load", setupGithubGraph);
</script>
